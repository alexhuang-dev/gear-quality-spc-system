GEAR_HISTORY_DB_PATH=/app/data/history.db
GEAR_CHECKPOINT_DB_PATH=/app/data/langgraph_checkpoints.sqlite
GEAR_OUTPUT_DIR=/app/data/reports
GEAR_HISTORY_LIMIT=20
GEAR_GENERATE_ARTIFACTS=true
GEAR_GENERATE_PDF=false
GEAR_WESTERN_ELECTRIC_ENABLED=true
GEAR_ALERT_CPK_THRESHOLD=1.0
GEAR_SEND_ALERTS=false
GEAR_ALERT_WEBHOOK_URL=
GEAR_ALERT_WEBHOOK_TYPE=generic
GEAR_LANGFUSE_ENABLED=false
GEAR_LANGFUSE_PUBLIC_KEY=
GEAR_LANGFUSE_SECRET_KEY=
GEAR_LANGFUSE_HOST=https://cloud.langfuse.com
GEAR_ARCHIVE_FAILED_HARNESS_CASES=true
GEAR_WATCH_DIR=/app/data/incoming
GEAR_PROCESSED_DIR=/app/data/processed
GEAR_FAILED_INPUTS_DIR=/app/data/failed_inputs
GEAR_SCAN_INTERVAL_SECONDS=30
